{
  "name": "observer",
  "private": true,
  "scripts": {
    "setup": "uv run python cli.py setup",
    "start": "uv run python cli.py start",
    "stop": "uv run python cli.py stop",
    "down": "uv run python cli.py down",
    "restart": "uv run python cli.py restart",
    "status": "uv run python cli.py status",
    "logs": "uv run python cli.py logs",
    "rebuild": "uv run python cli.py rebuild",
    "test": "uv run python cli.py test",
    "test:sources": "uv run python cli.py test sources",
    "test:web": "uv run python cli.py test web",
    "lint": "uv run ruff check src/ cli.py",
    "experiment": "uv run python cli.py experiment",
    "test:integration": "uv run python cli.py test-integration",
    "lint:fix": "uv run ruff check src/ cli.py --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}

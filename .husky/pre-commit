# Secret scanning
gitleaks protect --staged --verbose || exit 1

# Python: ruff lint
uv run ruff check src/ cli.py || exit 1

# Python: circular import check (import-linter)
PYTHONPATH=src uv run lint-imports || exit 1

# Python: unit tests (no DB, pure logic)
PYTHONPATH=src uv run pytest tests_unit/ -q || exit 1

# Python: source framework unit tests (Docker — skipped in pre-commit, run via npm test)

# JS/TS: unit tests (vitest)
(cd web && npx vitest run) || exit 1

# JS/TS: TypeScript compile check
(cd web && npx tsc -b) || exit 1

# JS/TS: knip dead code
(cd web && npx knip) || exit 1

# JS/TS: eslint (zero tolerance)
(cd web && npx eslint src/ --max-warnings 0) || exit 1

# JS/TS: circular import check (madge)
(cd web && npx madge --circular --extensions ts,tsx src/) || exit 1

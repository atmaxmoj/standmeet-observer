FROM python:3.12-slim

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

COPY pyproject.toml uv.lock ./
RUN uv sync --extra test --no-install-project

COPY src/ src/
COPY tests/ tests/
COPY tests_unit/ tests_unit/
COPY sources/builtin/ sources/builtin/
COPY cli.py .

ENV PYTHONPATH=/app/src
# Default: run integration tests (DB-dependent). Override CMD for unit tests.
CMD ["uv", "run", "pytest", "tests/", "--ignore=tests/unit", "--ignore=tests/integration", "-q", "--tb=short"]
